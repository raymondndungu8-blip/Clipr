# Shared secret — must match WORKER_SECRET in the Next.js app.
# All routes except /health require the x-worker-secret header to equal this.
WORKER_SECRET=

# Supabase (service role — server-side only, bypasses RLS for status updates)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (S3-compatible). No ACLs — public access comes from the
# bucket's public-bucket / custom-domain setting (R2_PUBLIC_URL).
CLOUDFLARE_R2_ACCOUNT_ID=
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Base URL of the deployed Next.js app — callbacks POST to
# ${APP_URL}/api/worker/callback
APP_URL=

# Supabase Storage bucket the browser uploads video files to directly
# (POST /process-upload downloads the file from here). Must match
# UPLOAD_BUCKET in the Next.js app's .env (defaults to "uploads" either way).
UPLOAD_BUCKET=uploads

# Port the worker listens on (Railway injects PORT automatically)
PORT=3001
